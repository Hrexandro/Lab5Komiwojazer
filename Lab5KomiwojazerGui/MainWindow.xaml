<Window x:Class="Lab5KomiwojazerGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Komiwojażer" Height="650" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Ustawienia" Grid.Row="0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Plik TSP:" VerticalAlignment="Center"/>
                <TextBox x:Name="TspPathTextBox" Grid.Column="1" Text="wi29.tsp" Margin="5"/>

                <TextBlock Grid.Column="2" Text="Zadania:" VerticalAlignment="Center"/>
                <TextBox x:Name="WorkerCountTextBox" Grid.Column="3" Text="4" Margin="5"/>

                <TextBlock Grid.Column="4" Text="Epoki:" VerticalAlignment="Center"/>
                <TextBox x:Name="EpochCountTextBox" Grid.Column="5" Text="100000" Margin="5"/>

                <TextBlock Grid.Column="6" Text="PMX:" VerticalAlignment="Center"/>
                <TextBox x:Name="PmxAttemptsTextBox" Grid.Column="7" Text="10000" Margin="5"/>

                <TextBlock Grid.Column="8" Text="3-opt [s]:" VerticalAlignment="Center"/>
                <TextBox x:Name="ThreeOptTimeTextBox" Grid.Column="9" Text="2" Margin="5"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10">
            <ComboBox x:Name="ModeComboBox" Width="160" SelectedIndex="0" Margin="0,0,10,0">
                <ComboBoxItem Content="TPL"/>
                <ComboBoxItem Content="ThreadPool"/>
            </ComboBox>

            <Button x:Name="StartButton" Content="Start" Width="100" Margin="0,0,10,0" Click="StartButton_Click"/>
            <Button x:Name="PauseButton" Content="Pauza" Width="100" Margin="0,0,10,0" Click="PauseButton_Click" IsEnabled="False"/>
            <Button x:Name="ResumeButton" Content="Wznów" Width="100" Margin="0,0,10,0" Click="ResumeButton_Click" IsEnabled="False"/>
            <Button x:Name="StopButton" Content="Stop" Width="100" Margin="0,0,10,0" Click="StopButton_Click" IsEnabled="False"/>
        </StackPanel>

        <GroupBox Header="Wyniki" Grid.Row="2" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Status:" FontWeight="Bold"/>
                <TextBlock x:Name="StatusTextBlock" Grid.Column="1" Text="Gotowy" Margin="5,0,20,0"/>

                <TextBlock Grid.Column="2" Text="Najlepszy wynik:" FontWeight="Bold"/>
                <TextBlock x:Name="BestLengthTextBlock" Grid.Column="3" Text="-" Margin="5,0,20,0"/>

                <TextBlock Grid.Column="4" Text="Policzone:" FontWeight="Bold"/>
                <TextBlock x:Name="ProcessedTextBlock" Grid.Column="5" Text="-" Margin="5,0,0,0"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Komunikaty" Grid.Row="3" Margin="0,10,0,0">
            <ListBox x:Name="LogListBox"/>
        </GroupBox>
    </Grid>
</Window>